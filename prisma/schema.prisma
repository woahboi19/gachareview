// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  reviews       Review[]
  upvotes       Upvote[]
  favorites     FavoriteGame[]
  role          String    @default("USER")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Game {
  id          String   @id @default(cuid())
  title       String
  description String
  imageUrl    String?
  developer   String
  chapters    StoryChapter[]
  reviews     Review[]
  favoritedBy FavoriteGame[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model StoryChapter {
  id          String   @id @default(cuid())
  gameId      String
  title       String
  chapterNum  Int
  summary     String
  imageUrl    String?  // Optional image for the chapter
  category    String   @default("Main Story")
  isMain      Boolean  @default(false)
  game        Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  reviews     Review[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Review {
  id          String   @id @default(cuid())
  rating      Float    // 0.5 to 5.0
  content     String
  isSpoiler   Boolean  @default(false)
  userId      String
  gameId      String?
  chapterId   String?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  game        Game?    @relation(fields: [gameId], references: [id], onDelete: Cascade)
  chapter     StoryChapter? @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  upvotes     Upvote[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, chapterId])
}

model Upvote {
  id        String   @id @default(cuid())
  userId    String
  reviewId  String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, reviewId])
}

model FavoriteGame {
  id        String   @id @default(cuid())
  userId    String
  gameId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, gameId])
}
